# env files
.env
*.env
.env.*

# Terraform local caches
.terraform/

# Terraform state files (sensitive)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Terraform plan output (can contain secrets in plaintext)
*.tfplan
*.tfplan.*

# Override files (local dev overrides, shouldn't be shared)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config (contains tokens)
.terraformrc
terraform.rc

# Sensitive var files
*.tfvars
*.tfvars.json
